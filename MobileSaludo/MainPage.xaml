<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileSaludo.MainPage"
             Title="Saludo móvil">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="16">

            <Label Text="Consumir API de Saludo"
                   FontSize="28"
                   FontAttributes="Bold" />

            <Label Text="Nombre" />
            <Entry x:Name="txtNombre"
                   Placeholder="Ingresa tu nombre" />

            <Label Text="Idioma" />
            <Picker x:Name="pickerIdioma"
                    Title="Seleccione un idioma">
                <Picker.Items>
                    <x:String>es</x:String>
                    <x:String>en</x:String>
                    <x:String>fr</x:String>
                </Picker.Items>
            </Picker>

            <Button Text="Saludar"
                    Clicked="OnSaludarClicked" />

            <Label Text="Resultado:"
                   FontSize="20"
                   FontAttributes="Bold" />

            <Label x:Name="lblResultado"
                   Text="Aquí aparecerá el mensaje"
                   FontSize="18" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>